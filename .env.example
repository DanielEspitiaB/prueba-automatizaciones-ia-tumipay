# Copia este archivo a .env y completa los valores. NUNCA subas el .env real.

# --- Anthropic Claude ---
# API key de la consola de Anthropic (https://console.anthropic.com/ -> API Keys)
ANTHROPIC_API_KEY=
# Modelo a usar. Haiku = económico, ideal para clasificación/extracción.
ANTHROPIC_MODEL=claude-haiku-4-5-20251001
# Pausa mínima entre llamadas, en segundos (0 = sin throttle). El tier de pago de
# Anthropic tiene límites holgados; subir solo si se quiere limitar el ritmo.
LLM_INTERVALO_SEG=0

# --- Base de datos ---
# Local (por defecto): SQLite, cero setup.
DATABASE_URL=sqlite:///solicitudes.db
# Producción: cambiar SOLO esta variable, p. ej.:
# DATABASE_URL=postgresql+psycopg2://usuario:password@host:5432/tumipay
